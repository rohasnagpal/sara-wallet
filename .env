# ══════════════════════════════════════════════════════════════════════════════
#  SARA — Configuration
#  Copy this file to .env.local and fill in your values. .env.local is where
#  the app actually reads its config from, and it's gitignored — this file
#  (.env) is just the tracked template, safe to commit.
# ══════════════════════════════════════════════════════════════════════════════

# ── AI (required) ─────────────────────────────────────────────────────────────
# Sara connects to AI models through OpenRouter (openrouter.ai) — one API key,
# hundreds of models to choose from (GPT, Claude, Gemini, Llama, and more).
LLM_PROVIDER=openrouter
LLM_MODEL=openai/gpt-4o-mini
OPENROUTER_API_KEY=

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./sara.db

# ── Market Data (optional) ───────────────────────────────────────────────────
# COINGECKO_API_KEY=CG-...              # higher rate limits: coingecko.com/api
# ALCHEMY_API_KEY=...                   # ERC-20 token balances: alchemy.com

# ── EVM RPC endpoints (optional — falls back to public RPCs if blank) ────────
# ETH_RPC=
# ARB_RPC=
# BASE_RPC=
# POLY_RPC=
# OP_RPC=
# BSC_RPC=
# AVAX_RPC=

# ── Solana (optional) ─────────────────────────────────────────────────────────
# HELIUS_RPC=https://...               # faster Solana RPC: helius.dev

# ── bName registration (optional) ────────────────────────────────────────────
# Buy a name like "rohas.sara" linked to your wallet. Requires a separately
# deployed registrar service.
# SARA_NAME_REGISTRAR_ADDRESS=
# SARA_NAME_LOG_ADDRESS=
# SARA_NAME_SERVICE_URL=
# SARA_NAME_REGISTRATION_FEE=10
# POLYGONSCAN_API_KEY=
